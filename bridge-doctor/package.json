{
  "name": "i99dash-example-bridge-doctor",
  "version": "0.1.8",
  "private": true,
  "description": "One-shot diagnostic mini-app that probes every i99dash bridge handler on the host and surfaces which work / which don't. Ships a one-tap DiShare passenger-cast reproducer.",
  "type": "module",
  "scripts": {
    "bundle": "esbuild src/app.js --bundle --format=iife --target=es2019 --outfile=src/app.bundle.js",
    "dev": "pnpm bundle && i99dash dev",
    "validate": "i99dash validate",
    "build": "pnpm bundle && i99dash build",
    "publish": "pnpm bundle && i99dash publish"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "i99dash": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "keytar"
    ]
  }
}
