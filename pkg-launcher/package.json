{
  "name": "i99dash-example-pkg-launcher",
  "version": "0.10.4",
  "private": true,
  "description": "Phase C reference mini-app — launches installed packages on any display + manages the boot-launch list.",
  "type": "module",
  "scripts": {
    "bundle": "esbuild src/app.js --bundle --format=iife --target=es2019 --outfile=src/app.bundle.js",
    "dev": "pnpm bundle && i99dash dev",
    "validate": "i99dash validate",
    "build": "pnpm bundle && i99dash build",
    "publish": "pnpm bundle && i99dash publish"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "i99dash": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "keytar"
    ]
  }
}
