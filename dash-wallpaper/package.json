{
  "name": "i99dash-example-dash-wallpaper",
  "version": "0.5.0",
  "private": true,
  "description": "Customize every screen in the car — gallery, upload, or live gradient. Renders on IVI, passenger screen, and cluster simultaneously via the surface family.",
  "type": "module",
  "scripts": {
    "bundle": "esbuild src/app.js --bundle --format=iife --target=es2019 --outfile=src/app.bundle.js",
    "dev": "pnpm bundle && i99dash dev",
    "validate": "i99dash validate",
    "build": "pnpm bundle && i99dash build",
    "publish": "pnpm bundle && i99dash publish"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "i99dash": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "keytar"]
  }
}
